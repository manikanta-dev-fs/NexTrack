# NexTrack Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit your actual .env file to git

# Security — generate a strong random key for production
# Run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string-in-production

# Database — choose ONE option:

# Option 1: SQLite (default, no setup needed for local dev)
# DATABASE_URL=sqlite+aiosqlite:///./data/nextrack.db

# Option 2: PostgreSQL (production / Docker)
# DATABASE_URL=postgresql+asyncpg://postgres:nextrack_secret@localhost:5432/nextrack_db

# Docker PostgreSQL password
POSTGRES_PASSWORD=nextrack_secret

# JWT Token Settings
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# Logging
LOG_LEVEL=INFO
