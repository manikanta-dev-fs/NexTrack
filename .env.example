# NexTrack Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit your actual .env file to git

# Security — generate a strong random key for production
# Run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string-in-production

# Database — SQLite (local file, no server needed)
DATABASE_URL=sqlite+aiosqlite:///./data/nextrack.db

# JWT Token Settings
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# Logging
LOG_LEVEL=INFO
